{
  "name": "scrummy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "scrummy": "./dist/bin/scrummy.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/bin/scrummy.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx src/bin/scrummy.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "scrummy": "file:.",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "esbuild@0.21.5": true
  }
}
